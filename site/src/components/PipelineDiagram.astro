---
// The run pipeline, drawn: config + dataset feed the engine, each case flows
// target -> scorers with the cassette docked under the target (CachedTarget
// wraps the target inside the engine), results fold into an ordered
// RunSummary, and gates / reporters / exit code read from it via a bus line.
//
// Layout is a strict grid (design/philosophy/06): the diagram's axis is
// x=360; output columns center on x=136/360/584; connectors are orthogonal,
// detached 4px from every box. Boxes use the shared fx-* raised-card
// vocabulary from landing.css — titles in the sans, literals in mono.
---

<figure class="ec-diagram">
	<svg viewBox="0 0 720 508" class="fx-svg pd-svg" role="img" aria-label="Diagram of the run pipeline: evals.yaml and cases.jsonl feed the engine, which runs target then scorers per case with the cassette recording and replaying beneath the target; results form an ordered RunSummary consumed by gates, reporters, and the exit code.">
		<defs>
			<marker id="pd-arr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
				<path d="M0 0 L10 5 L0 10 z" class="fx-arrow"></path>
			</marker>
		</defs>

		<!-- Inputs -->
		<rect x="195" y="6" width="150" height="48" rx="9" class="fx-svg-card"></rect>
		<rect x="375" y="6" width="150" height="48" rx="9" class="fx-svg-card"></rect>
		<text x="270" y="26" class="fx-label fx-mono" text-anchor="middle">evals.yaml</text>
		<text x="270" y="42" class="fx-sub" text-anchor="middle">suite config</text>
		<text x="450" y="26" class="fx-label fx-mono" text-anchor="middle">cases.jsonl</text>
		<text x="450" y="42" class="fx-sub" text-anchor="middle">dataset</text>
		<path d="M270 58 V84" class="fx-flow" marker-end="url(#pd-arr)"></path>
		<path d="M450 58 V84" class="fx-flow" marker-end="url(#pd-arr)"></path>

		<!-- Engine -->
		<rect x="120" y="92" width="480" height="212" rx="12" class="pd-engine"></rect>
		<text x="140" y="118" class="fx-label">engine</text>
		<text x="580" y="118" class="fx-sub fx-mono" text-anchor="end">per case · run.concurrency</text>

		<rect x="165" y="134" width="150" height="52" rx="9" class="fx-svg-card"></rect>
		<text x="240" y="156" class="fx-label" text-anchor="middle">target</text>
		<text x="240" y="174" class="fx-sub" text-anchor="middle">produces output</text>

		<path d="M319 160 H401" class="fx-flow" marker-end="url(#pd-arr)"></path>

		<rect x="405" y="134" width="150" height="52" rx="9" class="fx-svg-card"></rect>
		<text x="480" y="156" class="fx-label" text-anchor="middle">scorers</text>
		<text x="480" y="174" class="fx-sub" text-anchor="middle">judge the output</text>

		<!-- Cassette, docked under the target it wraps -->
		<rect x="165" y="234" width="150" height="56" rx="9" class="fx-accent-stroke"></rect>
		<text x="240" y="256" class="fx-label" text-anchor="middle">cassette</text>
		<text x="240" y="274" class="fx-sub" text-anchor="middle">record / replay</text>
		<path d="M225 190 V226" class="fx-flow" marker-end="url(#pd-arr)"></path>
		<path d="M255 230 V194" class="fx-flow" marker-end="url(#pd-arr)"></path>

		<!-- RunSummary -->
		<path d="M360 308 V336" class="fx-flow" marker-end="url(#pd-arr)"></path>
		<rect x="250" y="344" width="220" height="44" rx="9" class="fx-svg-card"></rect>
		<text x="360" y="362" class="fx-label" text-anchor="middle">RunSummary</text>
		<text x="360" y="378" class="fx-sub" text-anchor="middle">results in dataset order</text>

		<!-- Fan-out bus -->
		<path d="M360 392 V404 M136 404 H584" class="fx-flow"></path>
		<path d="M136 404 V416" class="fx-flow" marker-end="url(#pd-arr)"></path>
		<path d="M360 404 V416" class="fx-flow" marker-end="url(#pd-arr)"></path>
		<path d="M584 404 V416" class="fx-flow" marker-end="url(#pd-arr)"></path>

		<!-- Outputs -->
		<rect x="36" y="424" width="200" height="76" rx="9" class="fx-svg-card"></rect>
		<text x="136" y="450" class="fx-label" text-anchor="middle">gates</text>
		<text x="136" y="468" class="fx-sub fx-mono" text-anchor="middle">pass_rate · mean_score</text>
		<text x="136" y="484" class="fx-sub fx-mono" text-anchor="middle">+ baseline diff</text>

		<rect x="260" y="424" width="200" height="76" rx="9" class="fx-svg-card"></rect>
		<text x="360" y="450" class="fx-label" text-anchor="middle">reporters</text>
		<text x="360" y="468" class="fx-sub fx-mono" text-anchor="middle">terminal · json · junit</text>
		<text x="360" y="484" class="fx-sub fx-mono" text-anchor="middle">+ --html</text>

		<rect x="484" y="424" width="200" height="76" rx="9" class="fx-svg-card"></rect>
		<text x="584" y="450" class="fx-label" text-anchor="middle">exit code</text>
		<text x="584" y="468" class="fx-sub fx-mono" text-anchor="middle">0 = everything passed</text>
		<text x="584" y="484" class="fx-sub fx-mono" text-anchor="middle">1 = anything else</text>
	</svg>
	<figcaption>
		Cases move through the engine in dataset order and results return in that same order.
		Position is load-bearing.
	</figcaption>
</figure>

<style>
	.ec-diagram {
		margin: var(--sp-5) 0;
		padding: var(--sp-5);
		border: var(--border);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--sl-color-text) 2%, transparent);
		/* The svg keeps its legible min-width on phones; the card, not the page,
		 * is the scroll container. */
		overflow-x: auto;
	}
	.ec-diagram figcaption {
		margin-top: var(--sp-4);
		text-align: center;
		font-size: var(--fs-sm);
		color: var(--muted);
	}
	/* This diagram's viewBox is 720 wide; the shared .fx-svg cap of 480px shrank
	 * its labels to ~7px. Let it fill the column so text renders legibly. */
	.pd-svg {
		max-width: 100%;
	}
	.pd-engine {
		fill: transparent;
		stroke: var(--diagram-line);
		stroke-width: 1.5;
		stroke-dasharray: 5 5;
	}
</style>
