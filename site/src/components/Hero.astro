---
// Custom splash hero. Composed layout — badge, two-tone headline, subhead,
// actions, a mono proof strip, and the animated terminal — with a masked
// grid/glow background that fades out instead of clipping. Copy comes from
// the page's `hero:` frontmatter so it lives with the page.
import HeroTerminal from './landing/HeroTerminal.astro';

const route = Astro.locals.starlightRoute;
const hero = route.entry.data.hero ?? {};
const tagline = hero.tagline ?? '';
const actions = hero.actions ?? [];

const base = import.meta.env.BASE_URL;
const href = (link = '') =>
	/^(https?:)?\/\//.test(link) || link.startsWith('#')
		? link
		: `${base.replace(/\/$/, '')}/${link.replace(/^\//, '')}`;

const proof = ['$0 in CI', 'offline replay', 'no telemetry', 'any language'];
---

<section class="ec-hero">
	<div class="ec-hero-bg" aria-hidden="true"></div>
	<div class="ec-hero-glow" aria-hidden="true"></div>

	<p class="ec-eyebrow"><span class="ec-eyebrow-dot" aria-hidden="true"></span>Snapshot testing for AI behavior</p>

	<h1 class="ec-hero-title">
		Know when your AI gets worse,<br />
		<span class="ec-hero-title-muted">before your users do.</span>
	</h1>

	{tagline && <p class="ec-hero-tagline">{tagline}</p>}

	{
		actions.length > 0 && (
			<div class="ec-hero-actions">
				{actions.map((a) => (
					<a href={href(a.link)} class={`ec-btn ec-btn-${a.variant ?? 'secondary'}`}>
						{a.text}
						{a.variant === 'primary' && (
							<svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M9 5l7 7-7 7" />
							</svg>
						)}
					</a>
				))}
			</div>
		)
	}

	<ul class="ec-hero-proof" aria-label="At a glance">
		{
			proof.map((t) => (
				<li>
					<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 13l5 5 9-11" />
					</svg>
					{t}
				</li>
			))
		}
	</ul>

	<div class="ec-hero-terminal">
		<HeroTerminal />
	</div>
</section>
