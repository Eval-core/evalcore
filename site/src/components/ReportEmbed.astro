---
// The real thing, embedded: an actual report generated by the release binary
// from examples/quickstart (site/public/demo/quickstart-report.html). Shown in
// the site's window frame so readers see the artifact, not code describing it.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const src = `${base}/demo/quickstart-report.html`;
---

<figure class="ec-report-embed">
	<div class="ec-window-frame">
		<div class="ec-window-bar">
			<span class="ec-window-lights" aria-hidden="true"><i></i><i></i><i></i></span>
			<span class="ec-window-title">report.html</span>
			<a class="ec-window-open" href={src} target="_blank" rel="noopener">
				Open full report
				<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
			</a>
		</div>
		<iframe
			src={src}
			title="EvalCore HTML report for the quickstart suite: four passing cases, the gates panel, and expandable per-case scores"
			loading="lazy"
			sandbox="allow-same-origin"
			referrerpolicy="no-referrer"></iframe>
	</div>
	<figcaption>
		Generated by <code>evalcore run examples/quickstart/evals.yaml --html report.html</code>. This exact file, unedited.
	</figcaption>
</figure>

<style>
	.ec-report-embed {
		margin: var(--sp-5) 0;
	}
	.ec-window-frame {
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		background: var(--glass-bg);
		backdrop-filter: blur(var(--blur-glass));
		box-shadow:
			inset 0 1px 0 var(--glass-highlight),
			var(--shadow-lg);
		overflow: hidden;
	}
	.ec-window-bar {
		display: flex;
		align-items: center;
		gap: var(--sp-3);
		padding: 0.625rem var(--sp-4);
		border-bottom: 1px solid var(--glass-border);
	}
	.ec-window-lights {
		display: inline-flex;
		gap: 7px;
		flex: 1 0 0;
	}
	.ec-window-lights i {
		width: 11px;
		height: 11px;
		border-radius: 50%;
	}
	.ec-window-lights i:nth-child(1) {
		background: #ff5f57;
	}
	.ec-window-lights i:nth-child(2) {
		background: #febc2e;
	}
	.ec-window-lights i:nth-child(3) {
		background: #28c840;
	}
	.ec-window-title {
		font-family: var(--sl-font-mono);
		font-size: var(--fs-xs);
		color: var(--muted);
	}
	.ec-window-open {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		flex: 1 0 0;
		justify-content: flex-end;
		font-size: var(--fs-xs);
		font-weight: 500;
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}
	.ec-window-open:hover {
		text-decoration: underline;
	}
	iframe {
		display: block;
		width: 100%;
		/* Was a flat 560px, which on a phone left a tall iframe scrolling inside
		 * the page scroll. Cap to the viewport so the double scroll is small. */
		height: clamp(360px, 65vh, 560px);
		border: 0;
		background: var(--sl-color-bg);
		/* Propagate the SITE theme into the embedded report (it styles itself
		 * with prefers-color-scheme), so the frame never mismatches the page. */
		color-scheme: light;
	}
	:global([data-theme='dark']) iframe {
		color-scheme: dark;
	}
	figcaption {
		margin-top: var(--sp-3);
		text-align: center;
		font-size: var(--fs-sm);
		color: var(--muted);
	}
	figcaption code {
		font-size: 0.9em;
	}
</style>
