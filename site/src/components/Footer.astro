---
// Starlight `Footer` override. Two shapes, one component:
//  - landing (template: splash): the full four-column footer with the lockup —
//    it lives here and only here, so docs pages stop repeating it;
//  - docs pages: one slim hairline row, because the page just ended with
//    pagination and doesn't need a second site map.
import Logo from './Logo.astro';

const route = Astro.locals.starlightRoute;
const isSplash = route.entry.data.template === 'splash';

const repo = 'https://github.com/eval-core/evalcore';
const base = import.meta.env.BASE_URL;
const docs = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

const columns = [
	{
		title: 'Project',
		links: [
			{ label: 'GitHub', href: repo },
			{ label: 'crates.io', href: 'https://crates.io/crates/evalcore' },
			{ label: 'Changelog', href: `${repo}/blob/main/CHANGELOG.md` },
			{ label: 'Releases', href: `${repo}/releases` },
		],
	},
	{
		title: 'Docs',
		links: [
			{ label: 'Installation', href: docs('getting-started/installation/') },
			{ label: 'Quickstart', href: docs('getting-started/quickstart/') },
			{ label: 'Configuration', href: docs('reference/configuration/') },
			{ label: 'CLI reference', href: docs('reference/cli/') },
		],
	},
	{
		title: 'Community',
		links: [
			{ label: 'Contributing', href: `${repo}/blob/main/CONTRIBUTING.md` },
			{ label: 'Code of conduct', href: `${repo}/blob/main/CODE_OF_CONDUCT.md` },
			{ label: 'Security', href: `${repo}/blob/main/SECURITY.md` },
			{ label: 'Issues', href: `${repo}/issues` },
		],
	},
	{
		title: 'Legal',
		links: [{ label: 'Apache-2.0 license', href: `${repo}/blob/main/LICENSE` }],
	},
];
---

{
	isSplash ? (
		<footer class="ec-footer">
			<div class="ec-footer-cols">
				<div class="ec-footer-brand">
					<span class="ec-footer-lockup">
						<Logo size={24} />
						<span>EvalCore</span>
					</span>
					<p>Snapshot testing for AI behavior. Free and open source, Apache-2.0.</p>
				</div>
				{columns.map((col) => (
					<div class="ec-footer-col">
						<h2>{col.title}</h2>
						<ul>
							{col.links.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
			<div class="ec-footer-baseline">
				<span>No telemetry. No signup. No server.</span>
				<span>Apache-2.0</span>
			</div>
		</footer>
	) : (
		<footer class="ec-docs-footer">
			<span>Apache-2.0</span>
			<span class="ec-docs-footer-links">
				<a href={repo}>GitHub</a>
				<a href="https://crates.io/crates/evalcore">crates.io</a>
				<a href={`${repo}/issues`}>Issues</a>
			</span>
		</footer>
	)
}
