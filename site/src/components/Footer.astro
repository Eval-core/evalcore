---
// Site-wide footer: the credibility strip for an open-source launch. Rendered
// on every page above Starlight's default footer, which still carries the
// prev/next pagination on docs pages (via <Default>). Styles: chrome.css.
import Default from '@astrojs/starlight/components/Footer.astro';

const repo = 'https://github.com/eval-core/evalcore';
// Base-aware internal links: follow astro.config's `base`, so they keep working
// if it ever flips from /evalcore to /.
// BASE_URL may or may not carry a trailing slash; normalise so there is exactly
// one between the base and the path.
const base = import.meta.env.BASE_URL;
const docs = (p) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

const columns = [
	{
		title: 'Project',
		links: [
			{ label: 'GitHub', href: repo },
			{ label: 'crates.io', href: 'https://crates.io/crates/evalcore' },
			{ label: 'Changelog', href: `${repo}/blob/main/CHANGELOG.md` },
			{ label: 'Releases', href: `${repo}/releases` },
		],
	},
	{
		title: 'Docs',
		links: [
			{ label: 'Installation', href: docs('getting-started/installation/') },
			{ label: 'Quickstart', href: docs('getting-started/quickstart/') },
			{ label: 'Configuration', href: docs('reference/configuration/') },
			{ label: 'CLI reference', href: docs('reference/cli/') },
		],
	},
	{
		title: 'Community',
		links: [
			{ label: 'Contributing', href: `${repo}/blob/main/CONTRIBUTING.md` },
			{ label: 'Code of conduct', href: `${repo}/blob/main/CODE_OF_CONDUCT.md` },
			{ label: 'Security', href: `${repo}/blob/main/SECURITY.md` },
			{ label: 'Issues', href: `${repo}/issues` },
		],
	},
	{
		title: 'Legal',
		links: [{ label: 'Apache-2.0 license', href: `${repo}/blob/main/LICENSE` }],
	},
];
---

<div class="ec-footer">
	<div class="ec-footer-cols">
		{
			columns.map((col) => (
				<div class="ec-footer-col">
					<h2>{col.title}</h2>
					<ul>
						{col.links.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
					{col.title === 'Legal' && (
						<p class="ec-footer-note">No telemetry. No signup. No server.</p>
					)}
				</div>
			))
		}
	</div>
	<div class="ec-footer-baseline">
		EvalCore is free and open source under the Apache-2.0 license.
	</div>
</div>

<Default><slot /></Default>
