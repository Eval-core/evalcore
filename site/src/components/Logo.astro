---
// The EvalCore mark ("breakthrough"): three score bars forming an E, one
// crossing the muted threshold line and turning accent past it — a pass,
// drawn. Inline SVG so the bars inherit text color per theme; only the
// crossing tip carries the accent.
interface Props {
	size?: number;
}
const { size = 28 } = Astro.props;
---

<svg
	width={size}
	height={size}
	viewBox="0 0 64 64"
	fill="none"
	aria-hidden="true"
	class="ec-logo"
>
	<rect x="39" y="9" width="4" height="46" rx="2" fill="currentColor" opacity="0.32"></rect>
	<rect x="10" y="13" width="26" height="10" rx="5" fill="currentColor"></rect>
	<rect x="10" y="27" width="20" height="10" rx="5" fill="currentColor"></rect>
	<path d="M15 41 A5 5 0 0 0 10 46 A5 5 0 0 0 15 51 H41 V41 Z" fill="currentColor"></path>
	<path
		d="M41 41 H49 A5 5 0 0 1 54 46 A5 5 0 0 1 49 51 H41 Z"
		fill="var(--sl-color-accent, #2dd4a0)"></path>
</svg>
