---
// "Latest release" chip. Shows the version the site was built against, bumped
// each release. No runtime call: the footer promises "No telemetry. No
// server.", and a fetch to api.github.com on every page load would break that
// promise (and leak the reader's IP to GitHub). The link always points at the
// latest release for the authoritative number.
interface Props {
	version?: string;
}
const { version = 'v0.7.5' } = Astro.props;
---

<p class="ec-release-badge">
	<span class="ec-release-dot" aria-hidden="true"></span>
	Latest release:
	<a href="https://github.com/eval-core/evalcore/releases/latest"><code>{version}</code></a>
</p>
